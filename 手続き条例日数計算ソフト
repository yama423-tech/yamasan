<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>林地開発行為 手続き期間計算ツール</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; color: #333; padding: 20px; }
        .container { max-width: 600px; margin: 0 auto; background: #fff; padding: 25px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h2 { text-align: center; color: #2c3e50; font-size: 1.4em; border-bottom: 2px solid #3498db; padding-bottom: 10px; }
        .form-group { margin-bottom: 20px; }
        label { display: block; font-weight: bold; margin-bottom: 8px; color: #34495e; }
        input[type="date"] { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 1em; }
        button { width: 100%; padding: 12px; background-color: #3498db; color: white; border: none; border-radius: 4px; font-size: 1.1em; cursor: pointer; transition: background-color 0.3s; }
        button:hover { background-color: #2980b9; }
        .result-box { margin-top: 25px; padding: 15px; background-color: #e8f6f3; border-left: 5px solid #1abc9c; display: none; }
        .result-item { margin-bottom: 10px; font-size: 1.1em; }
        .result-item span { font-weight: bold; color: #c0392b; }
        .radio-group { margin-bottom: 20px; }
        .radio-group label { display: block; font-weight: bold; margin-bottom: 8px; color: #34495e; }
        .radio-option { display: block; margin-bottom: 6px; font-weight: normal; cursor: pointer; }
        .radio-option input { margin-right: 6px; }
        .note { font-size: 0.85em; color: #7f8c8d; margin-top: 15px; }
    </style>
</head>
<body>

<div class="container">
    <h2>林地開発行為 法定期間計算ツール</h2>
    
    <div class="form-group">
        <label for="announceDate">公告日を選択してください</label>
        <input type="date" id="announceDate">
    </div>
    
    <div class="radio-group">
        <label>説明会の開催</label>
        <label class="radio-option"><input type="radio" name="meetingOption" value="yes" checked>説明会を開催する</label>
        <label class="radio-option"><input type="radio" name="meetingOption" value="no">説明会を開催しない</label>
    </div>

    <button onclick="calculateDates()">期間を計算する</button>

    <div class="result-box" id="resultBox">
        <div class="result-item">１．公告日（起算日）: <br><span id="resAnnounce"></span></div>
        <div class="result-item">２．縦覧終了日（1月間・休日調整後）: <br><span id="resInspection"></span></div>
        <div class="result-item" id="resOpinionItem">３．意見書提出期限: <br><span id="resOpinion"></span></div>
        <p class="note">※本ツールは民法第143条及び行政機関休日法に準拠しています。<br>※祝日データは外部API（holidays-jp）から取得しています。年末年始等の閉庁日は自治体により異なる場合があるため、実務上の最終確認は必ず行ってください。</p>
    </div>
</div>

<script>
    let holidays = {};

    // 祝日APIの非同期取得
    fetch('https://holidays-jp.github.io/api/v1/date.json')
        .then(response => response.json())
        .then(data => { holidays = data; })
        .catch(error => console.error('祝日データの取得に失敗しました:', error));

    // 休日判定関数（土・日・祝日）
    function isHoliday(dateObj) {
        const day = dateObj.getDay();
        if (day === 0 || day === 6) return true; // 日(0)・土(6)
        
        const y = dateObj.getFullYear();
        const m = String(dateObj.getMonth() + 1).padStart(2, '0');
        const d = String(dateObj.getDate()).padStart(2, '0');
        const dateString = `${y}-${m}-${d}`;
        
        return holidays.hasOwnProperty(dateString);
    }

    // 翌開庁日の探索関数
    function getNextBusinessDay(dateObj) {
        let current = new Date(dateObj);
        while (isHoliday(current)) {
            current.setDate(current.getDate() + 1);
        }
        return current;
    }

    // 和暦表示用フォーマット関数
    function formatDateJP(dateObj) {
        return new Intl.DateTimeFormat('ja-JP-u-ca-japanese', { 
            era: 'long', year: 'numeric', month: 'long', day: 'numeric', weekday: 'short' 
        }).format(dateObj);
    }

    // 民法143条に基づく「1月後」の計算関数
    function getCivilCodeOneMonthLater(startDate) {
        let year = startDate.getFullYear();
        let month = startDate.getMonth() + 1;
        let day = startDate.getDate();

        let targetYear = year;
        let targetMonth = month + 1;
        if (targetMonth > 12) {
            targetMonth = 1;
            targetYear++;
        }

        // 翌月の日数を取得
        let daysInTargetMonth = new Date(targetYear, targetMonth, 0).getDate();

        if (day > daysInTargetMonth) {
            // 応当日がない場合（例：1/31 → 2/28）はその月の末日
            return new Date(targetYear, targetMonth - 1, daysInTargetMonth);
        } else {
            // 応当日の前日
            let result = new Date(targetYear, targetMonth - 1, day);
            result.setDate(result.getDate() - 1);
            return result;
        }
    }

    function calculateDates() {
        const inputVal = document.getElementById('announceDate').value;
        if (!inputVal) {
            alert('公告日を入力してください。');
            return;
        }

        const announceDate = new Date(inputVal);

        // 1. 公告日（表示用）
        document.getElementById('resAnnounce').innerText = formatDateJP(announceDate);

        // 2. 縦覧終了日の計算（1月後・応当日の前日）
        let rawInspectionEnd = getCivilCodeOneMonthLater(announceDate);
        let finalInspectionEnd = getNextBusinessDay(rawInspectionEnd);
        document.getElementById('resInspection').innerText = formatDateJP(finalInspectionEnd);

        // 3. 意見書提出期限の計算
        const hasMeeting = document.querySelector('input[name="meetingOption"]:checked').value === 'yes';
        let finalOpinionEnd;

        if (hasMeeting) {
            // 説明会開催する場合：縦覧終了日の翌日から2週間=14日目
            let opinionStartDate = new Date(finalInspectionEnd);
            opinionStartDate.setDate(opinionStartDate.getDate() + 1); // 翌日から起算
            let rawOpinionEnd = new Date(opinionStartDate);
            rawOpinionEnd.setDate(rawOpinionEnd.getDate() + 13); // 1日目 + 13日 = 14日目
            finalOpinionEnd = getNextBusinessDay(rawOpinionEnd);
            document.getElementById('resOpinionItem').innerHTML =
                '３．意見書提出期限（説明会開催：終了日翌日から2週間）: <br><span id="resOpinion"></span>';
        } else {
            // 説明会開催しない場合：縦覧終了日が意見書提出期限
            finalOpinionEnd = finalInspectionEnd;
            document.getElementById('resOpinionItem').innerHTML =
                '３．意見書提出期限（説明会なし：縦覧終了日）: <br><span id="resOpinion"></span>';
        }
        document.getElementById('resOpinion').innerText = formatDateJP(finalOpinionEnd);

        // 結果領域の表示
        document.getElementById('resultBox').style.display = 'block';
    }
</script>

</body>
</html>
