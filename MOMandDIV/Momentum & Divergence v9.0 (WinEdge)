//@version=6
indicator("Momentum & Divergence v9.0 (WinEdge)", overlay=true, max_lines_count=500, max_labels_count=500, max_bars_back=5000)

// ==========================================
// 1. トレードスタイル & 感度設定
// ==========================================
groupStrat = "📊 トレードスタイル & 感度設定"
tradeStyle = input.string("スイング", "トレードスタイル", options=["短期","スイング","中期","長期"], group=groupStrat)
sensitivity = input.string("Lv3: Scalper (Center)", "感度レベル", options=["Lv1: Swing (Solid)", "Lv2: Strict", "Lv3: Scalper (Center)", "Lv4: Fast", "Lv5: Normal"], group=groupStrat)
useCustom   = input.bool(false, "詳細パラメータを手動設定する", group=groupStrat)
src         = input.source(close, "価格ソース", group=groupStrat)
rsiLen      = input.int(14, "RSI期間", minval=2, group=groupStrat)

// 足自動調整
tfSeconds = timeframe.in_seconds()
tfCat = tfSeconds <= 300 ? 1 : tfSeconds <= 1800 ? 2 : tfSeconds <= 14400 ? 3 : tfSeconds <= 86400 ? 4 : 5
tfScaleL   = tfCat == 1 ? 0.5 : tfCat == 2 ? 0.75 : tfCat == 3 ? 1.0 : tfCat == 4 ? 1.5 : 2.0
tfScaleGap = tfCat == 1 ? 0.5 : tfCat == 2 ? 0.75 : tfCat == 3 ? 1.0 : tfCat == 4 ? 1.25 : 1.5
tfRsiAdj   = tfCat == 1 ? -3 : tfCat == 2 ? -1 : tfCat == 3 ? 0 : tfCat == 4 ? 1 : 2

styleScaleL   = tradeStyle == "短期" ? 0.6 : tradeStyle == "スイング" ? 1.0 : tradeStyle == "中期" ? 1.4 : 2.0
styleScaleGap = tradeStyle == "短期" ? 0.5 : tradeStyle == "スイング" ? 1.0 : tradeStyle == "中期" ? 1.3 : 1.8
styleRsiAdj   = tradeStyle == "短期" ? -2 : tradeStyle == "スイング" ? 0 : tradeStyle == "中期" ? 1 : 2

var int baseL = na
var int baseR = na
var int baseGap = na
var int baseRsiUp = na
var int baseRsiDn = na

if sensitivity == "Lv1: Swing (Solid)"
    baseL := 20
    baseR := 20
    baseGap := 20
    baseRsiUp := 60
    baseRsiDn := 40
else if sensitivity == "Lv2: Strict"
    baseL := 10
    baseR := 10
    baseGap := 15
    baseRsiUp := 58
    baseRsiDn := 42
else if sensitivity == "Lv3: Scalper (Center)"
    baseL := 2
    baseR := 2
    baseGap := 2
    baseRsiUp := 52
    baseRsiDn := 48
else if sensitivity == "Lv4: Fast"
    baseL := 4
    baseR := 4
    baseGap := 5
    baseRsiUp := 54
    baseRsiDn := 46
else
    baseL := 6
    baseR := 6
    baseGap := 10
    baseRsiUp := 55
    baseRsiDn := 45

scaledL = int(math.max(1, math.round(baseL * tfScaleL * styleScaleL)))
scaledR = int(math.max(1, math.round(baseR * tfScaleL * styleScaleL)))
scaledGap = int(math.max(1, math.round(baseGap * tfScaleGap * styleScaleGap)))
scaledRsiUp = int(math.min(70, math.max(50, baseRsiUp + tfRsiAdj + styleRsiAdj)))
scaledRsiDn = int(math.max(30, math.min(50, baseRsiDn - tfRsiAdj - styleRsiAdj)))

L      = useCustom ? input.int(6, "Pivot 左", group=groupStrat) : scaledL
R      = useCustom ? input.int(6, "Pivot 右", group=groupStrat) : scaledR
minGap = useCustom ? input.int(10, "Pivot間隔", group=groupStrat) : scaledGap
rsiUp  = useCustom ? input.int(55, "RSI基準(上)", group=groupStrat) : scaledRsiUp
rsiDn  = useCustom ? input.int(45, "RSI基準(下)", group=groupStrat) : scaledRsiDn

// MACD設定
groupMACD = "MACD設定"
baseFast = input.int(12, "MACD Fast", group=groupMACD)
baseSlow = input.int(26, "MACD Slow", group=groupMACD)
baseSig  = input.int(9, "MACD Signal", group=groupMACD)
macdTfScale = tfCat == 1 ? 0.7 : tfCat == 2 ? 0.85 : tfCat == 3 ? 1.0 : tfCat == 4 ? 1.0 : 1.2
fast = useCustom ? baseFast : int(math.max(3, math.round(baseFast * macdTfScale)))
slow = useCustom ? baseSlow : int(math.max(8, math.round(baseSlow * macdTfScale)))
sig  = useCustom ? baseSig : int(math.max(3, math.round(baseSig * macdTfScale)))

// ==========================================
// 2. レジーム & エッジフィルタ
// ==========================================
groupRegime = "🔄 レジーム自動判定"
useRegime = input.bool(true, "レジーム自動調整を有効化", group=groupRegime)
regimeLookback = input.int(60, "レジーム判定ルックバック", minval=20, maxval=200, group=groupRegime)

regimeEma = ta.ema(close, 200)
regimeAtr = ta.atr(14)
regimeAtrPct = close != 0 ? (regimeAtr / close) * 100.0 : 0.0
avgAtrPct = ta.sma(regimeAtrPct, regimeLookback)
atrRatio = avgAtrPct > 0 ? regimeAtrPct / avgAtrPct : 1.0
recentHigh = ta.highest(high, regimeLookback)
drawdownPct = recentHigh > 0 ? ((recentHigh - close) / recentHigh) * 100.0 : 0.0
roc10 = ta.roc(close, 10)

var int regime = 5
if drawdownPct > 15 and roc10 < -5 and atrRatio > 1.8
    regime := 1
else if close < regimeEma and roc10 < -2
    regime := 2
else if atrRatio > 1.6 and math.abs(ta.roc(regimeEma, 5)) < 0.7
    regime := 3
else if close > regimeEma and roc10 > 2
    regime := 4
else
    regime := 5

regimeName = regime == 1 ? "暴落" : regime == 2 ? "下降" : regime == 3 ? "高ボラ" : regime == 4 ? "上昇" : "通常"
regimeThreshAdj = regime == 1 ? -4 : regime == 2 ? -2 : regime == 3 ? -2 : regime == 4 ? 2 : 0

adjRsiUp = useRegime ? int(math.min(70, math.max(50, rsiUp + regimeThreshAdj))) : rsiUp
adjRsiDn = useRegime ? int(math.max(30, math.min(50, rsiDn - regimeThreshAdj))) : rsiDn
adjMinGap = useRegime ? int(math.max(1, math.round(minGap * (regime == 1 ? 0.75 : regime == 4 ? 1.05 : 1.0)))) : minGap

// HTFバイアス
groupEdge = "🏆 勝率改善フィルタ"
useHtfBias = input.bool(true, "上位足EMA方向を必須化", group=groupEdge)
htfTf = input.string("D", "上位足", options=["240", "D", "W"], group=groupEdge)
htfEmaLen = input.int(200, "上位足EMA", minval=20, group=groupEdge)
minQuality = input.int(3, "最小クオリティ(0-7)", minval=0, maxval=7, group=groupEdge)

htfClose = request.security(syminfo.tickerid, htfTf, close)
htfEma = request.security(syminfo.tickerid, htfTf, ta.ema(close, htfEmaLen))
htfBull = htfClose > htfEma
htfBear = htfClose < htfEma

// ==========================================
// 3. コンボウィンドウ設定 (v8.1のバグ修正の核心)
// ==========================================
groupCombo = "🔗 MOM × Div コンボ設定"
comboBars  = input.int(30, "許容ウィンドウ本数", minval=5, maxval=100, group=groupCombo, tooltip="ダイバージェンスとモメンタム転換がこの本数以内に発生すればシグナル成立")
orderOpt   = input.string("どちらでも", "発生順序", options=["Div→MOMのみ","MOM→Divのみ","どちらでも"], group=groupCombo)

// ==========================================
// 4. 出来高フィルタ
// ==========================================
groupVol = "📊 出来高フィルタ"
useVolFilt = input.bool(false, "出来高スパイクをフィルタに使用", group=groupVol)
volLen     = input.int(20, "出来高SMA期間", minval=2, group=groupVol)
volMult    = input.float(1.5, "倍率しきい値", minval=1.0, step=0.1, group=groupVol)

// ==========================================
// 5. 確定ロジック
// ==========================================
groupC = "確定ロジック"
useTrendFilt  = input.bool(true, "EMAトレンド条件", group=groupC)
maLen         = input.int(200, "EMA期間", group=groupC)
trendBars     = input.int(5, "EMA向き確認本数", group=groupC)
useMACDconf   = input.bool(true, "MACDクロス必須", group=groupC)
useRSIconf    = input.bool(true, "RSI>50/<50必須", group=groupC)
useSwingBreak = input.bool(false, "戻り高値/安値ブレイク必須", group=groupC)

// ==========================================
// 6. SL/TP設定
// ==========================================
groupSLTP = "🎯 SL/TP 表示"
showSLTP    = input.bool(true, "SL/TPラインを表示", group=groupSLTP)
slAtrMult   = input.float(1.5, "SL ATR倍率", step=0.1, minval=0.5, maxval=5.0, group=groupSLTP)
tpRR        = input.float(2.0, "TP リスクリワード比", step=0.1, minval=1.0, maxval=5.0, group=groupSLTP)
slLineLen   = input.int(20, "ライン表示本数", minval=5, maxval=100, group=groupSLTP)

// ==========================================
// 7. 表示制御
// ==========================================
groupView = "表示制御"
showLabels  = input.bool(true, "ラベル表示", group=groupView)
showMOM     = input.bool(true, "MOM（初動）ラベル", group=groupView)
showDiv     = input.bool(true, "DIV（ダイバージェンス）ラベル", group=groupView)
showCombo   = input.bool(true, "BUY/SELLシグナル", group=groupView)
showDebug   = input.bool(true, "デバッグテーブル", group=groupView)
showDivLine = input.bool(true, "ダイバージェンスライン", group=groupView)
labelGapBars = input.int(3, "ラベル重複回避(最小間隔)", minval=0, group=groupView)

// ==========================================
// 計算ロジック
// ==========================================
rsi = ta.rsi(src, rsiLen)
macdLine = ta.ema(src, fast) - ta.ema(src, slow)
signalLine = ta.ema(macdLine, sig)
hist = macdLine - signalLine

volSma   = ta.sma(volume, volLen)
volSpike = volume > volSma * volMult

// モメンタム転換（MOM）
momUp = ta.crossover(hist, 0) and rsi > adjRsiUp and (not useVolFilt or volSpike)
momDn = ta.crossunder(hist, 0) and rsi < adjRsiDn and (not useVolFilt or volSpike)

// ==========================================
// ダイバージェンス関数 (修正版)
// - trigBarを返し、ライン描画対応
// - var変数で前回ピボットを正しく保持
// ==========================================
f_div(series float srcSeries, series float oscSeries, int L_, int R_, int gap_, bool isBull) =>
    float pivotVal = isBull ? ta.pivotlow(srcSeries, L_, R_) : ta.pivothigh(srcSeries, L_, R_)
    float oscVal   = isBull ? ta.pivotlow(oscSeries, L_, R_) : ta.pivothigh(oscSeries, L_, R_)
    var float prevPivot = na
    var float prevOsc = na
    var int prevBar = na
    bool detected = false
    int trigBar = na
    float prevPivotOut = na
    int prevBarOut = na

    if not na(pivotVal) and not na(oscVal)
        currBar = bar_index - R_
        gapOK = not na(prevBar) and (currBar - prevBar >= gap_)
        cond = isBull ? (pivotVal < prevPivot and oscVal > prevOsc) : (pivotVal > prevPivot and oscVal < prevOsc)
        if gapOK and cond
            detected := true
            trigBar := currBar
            prevPivotOut := prevPivot
            prevBarOut := prevBar
        prevPivot := pivotVal
        prevOsc   := oscVal
        prevBar   := currBar
    [detected, trigBar, pivotVal, prevPivotOut, prevBarOut]

// ダイバージェンス検出（RSI + MACD histの両方）
[bRSI, bRSIbar, bRSIpv, bRSIpp, bRSIpb]   = f_div(src, rsi,  L, R, adjMinGap, true)
[sRSI, sRSIbar, sRSIpv, sRSIpp, sRSIpb]   = f_div(src, rsi,  L, R, adjMinGap, false)
[bMACD, bMACDbar, bMACDpv, bMACDpp, bMACDpb] = f_div(src, hist, L, R, adjMinGap, true)
[sMACD, sMACDbar, sMACDpv, sMACDpp, sMACDpb] = f_div(src, hist, L, R, adjMinGap, false)

bullDivAny = bRSI or bMACD
bearDivAny = sRSI or sMACD

// ダイバージェンスライン描画
if showDivLine and bRSI and not na(bRSIbar) and not na(bRSIpb)
    line.new(bRSIpb, bRSIpp, bRSIbar, bRSIpv, xloc=xloc.bar_index, color=color.new(color.teal, 40), width=2, style=line.style_solid)
if showDivLine and sRSI and not na(sRSIbar) and not na(sRSIpb)
    line.new(sRSIpb, sRSIpp, sRSIbar, sRSIpv, xloc=xloc.bar_index, color=color.new(color.maroon, 40), width=2, style=line.style_solid)
if showDivLine and bMACD and not na(bMACDbar) and not na(bMACDpb)
    line.new(bMACDpb, bMACDpp, bMACDbar, bMACDpv, xloc=xloc.bar_index, color=color.new(color.teal, 60), width=1, style=line.style_dashed)
if showDivLine and sMACD and not na(sMACDbar) and not na(sMACDpb)
    line.new(sMACDpb, sMACDpp, sMACDbar, sMACDpv, xloc=xloc.bar_index, color=color.new(color.maroon, 60), width=1, style=line.style_dashed)

// ==========================================
// 確定フィルタ
// ==========================================
emaTrend = ta.ema(close, maLen)
emaUp    = ta.rising(emaTrend, trendBars)
emaDn    = ta.falling(emaTrend, trendBars)

trendBullOK = (not useTrendFilt) or close > emaTrend or emaUp
trendBearOK = (not useTrendFilt) or close < emaTrend or emaDn

momBullOK = (not useMACDconf) or ta.crossover(macdLine, signalLine) or ta.crossover(hist, 0)
momBearOK = (not useMACDconf) or ta.crossunder(macdLine, signalLine) or ta.crossunder(hist, 0)

rsiBullOK = (not useRSIconf) or rsi > 50
rsiBearOK = (not useRSIconf) or rsi < 50

// 戻り高値/安値ブレイク
bsDivBull = ta.barssince(bullDivAny)
bsDivBear = ta.barssince(bearDivAny)
hhSinceDiv = (bsDivBull >= 1 and bsDivBull <= comboBars) ? ta.highest(high, bsDivBull + 1) : na
llSinceDiv = (bsDivBear >= 1 and bsDivBear <= comboBars) ? ta.lowest(low,  bsDivBear + 1) : na
breakUpOK = (not useSwingBreak) or (not na(hhSinceDiv) and ta.crossover(close, hhSinceDiv))
breakDnOK = (not useSwingBreak) or (not na(llSinceDiv) and ta.crossunder(close, llSinceDiv))

// ==========================================
// コンボシグナル (v8.1のバグ修正: ルックバック窓方式)
// ==========================================
bs_bullDiv = ta.barssince(bullDivAny)
bs_bearDiv = ta.barssince(bearDivAny)
bs_momUp   = ta.barssince(momUp)
bs_momDn   = ta.barssince(momDn)

// Div先 → MOM後 (Divが先に発生し、comboBars以内にMOMが来た)
divThenMomUp = bs_bullDiv >= 1 and bs_bullDiv <= comboBars and momUp
divThenMomDn = bs_bearDiv >= 1 and bs_bearDiv <= comboBars and momDn
// MOM先 → Div後
momThenDivUp = bs_momUp >= 1 and bs_momUp <= comboBars and bullDivAny
momThenDivDn = bs_momDn >= 1 and bs_momDn <= comboBars and bearDivAny

comboRawBull = (orderOpt != "MOM→Divのみ" and divThenMomUp) or (orderOpt != "Div→MOMのみ" and momThenDivUp)
comboRawBear = (orderOpt != "MOM→Divのみ" and divThenMomDn) or (orderOpt != "Div→MOMのみ" and momThenDivDn)

// ==========================================
// クオリティスコア (7点満点に拡張)
// ==========================================
// 1. トレンド方向一致
// 2. MACDクロス確認
// 3. RSI方向確認
// 4. ボラティリティ安定
// 5. EMA上/下
// 6. 出来高サポート
// 7. HTFバイアス一致
bullQuality = (trendBullOK ? 1 : 0) + (momBullOK ? 1 : 0) + (rsiBullOK ? 1 : 0) + (atrRatio <= 1.8 ? 1 : 0) + (close > emaTrend ? 1 : 0) + (volSpike ? 1 : 0) + (htfBull ? 1 : 0)
bearQuality = (trendBearOK ? 1 : 0) + (momBearOK ? 1 : 0) + (rsiBearOK ? 1 : 0) + (atrRatio <= 1.8 ? 1 : 0) + (close < emaTrend ? 1 : 0) + (volSpike ? 1 : 0) + (htfBear ? 1 : 0)

// ==========================================
// 最終シグナル
// ==========================================
bullSignal = comboRawBull and trendBullOK and breakUpOK and (not useHtfBias or htfBull) and bullQuality >= minQuality
bearSignal = comboRawBear and trendBearOK and breakDnOK and (not useHtfBias or htfBear) and bearQuality >= minQuality

// ==========================================
// SL/TP計算
// ==========================================
atrVal = ta.atr(14)
var float bullSL = na
var float bullTP = na
var float bearSL = na
var float bearTP = na

if bullSignal
    bullSL := close - atrVal * slAtrMult
    risk = close - bullSL
    bullTP := close + risk * tpRR

if bearSignal
    bearSL := close + atrVal * slAtrMult
    risk = bearSL - close
    bearTP := close - risk * tpRR

// SL/TP ライン描画
if showSLTP and bullSignal
    line.new(bar_index, bullSL, bar_index + slLineLen, bullSL, color=color.new(color.red, 30), width=1, style=line.style_dotted)
    line.new(bar_index, bullTP, bar_index + slLineLen, bullTP, color=color.new(color.green, 30), width=1, style=line.style_dotted)
    label.new(bar_index + slLineLen, bullSL, "SL " + str.tostring(bullSL, format.mintick), style=label.style_label_left, color=color.new(color.red, 80), textcolor=color.red, size=size.tiny)
    label.new(bar_index + slLineLen, bullTP, "TP " + str.tostring(bullTP, format.mintick), style=label.style_label_left, color=color.new(color.green, 80), textcolor=color.green, size=size.tiny)

if showSLTP and bearSignal
    line.new(bar_index, bearSL, bar_index + slLineLen, bearSL, color=color.new(color.red, 30), width=1, style=line.style_dotted)
    line.new(bar_index, bearTP, bar_index + slLineLen, bearTP, color=color.new(color.green, 30), width=1, style=line.style_dotted)
    label.new(bar_index + slLineLen, bearSL, "SL " + str.tostring(bearSL, format.mintick), style=label.style_label_left, color=color.new(color.red, 80), textcolor=color.red, size=size.tiny)
    label.new(bar_index + slLineLen, bearTP, "TP " + str.tostring(bearTP, format.mintick), style=label.style_label_left, color=color.new(color.green, 80), textcolor=color.green, size=size.tiny)

// ==========================================
// 描画
// ==========================================
var int lastMomUp = na
var int lastMomDn = na
var int lastDivUp = na
var int lastDivDn = na
var int lastBuy = na
var int lastSell = na
allow(int lastBar) => na(lastBar) or (bar_index - lastBar >= labelGapBars)

if showLabels
    // MOM ラベル
    if showMOM and momUp and allow(lastMomUp)
        label.new(bar_index, low, "MOM▲", style=label.style_label_up, color=color.new(color.fuchsia, 70), textcolor=color.white, size=size.tiny)
        lastMomUp := bar_index
    if showMOM and momDn and allow(lastMomDn)
        label.new(bar_index, high, "MOM▼", style=label.style_label_down, color=color.new(color.orange, 70), textcolor=color.white, size=size.tiny)
        lastMomDn := bar_index

    // DIV ラベル
    if showDiv and bullDivAny and allow(lastDivUp)
        label.new(bar_index, low, "DIV▲", style=label.style_label_up, color=color.new(color.aqua, 70), textcolor=color.white, size=size.tiny)
        lastDivUp := bar_index
    if showDiv and bearDivAny and allow(lastDivDn)
        label.new(bar_index, high, "DIV▼", style=label.style_label_down, color=color.new(color.red, 70), textcolor=color.white, size=size.tiny)
        lastDivDn := bar_index

    // BUY/SELL シグナル（メイン）
    if showCombo and bullSignal and allow(lastBuy)
        qTxt = " Q" + str.tostring(bullQuality)
        label.new(bar_index, low, "BUY" + qTxt, style=label.style_label_up, color=color.new(color.lime, 0), textcolor=color.white, size=size.normal)
        lastBuy := bar_index
    if showCombo and bearSignal and allow(lastSell)
        qTxt = " Q" + str.tostring(bearQuality)
        label.new(bar_index, high, "SELL" + qTxt, style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.normal)
        lastSell := bar_index

// EMAライン
plot(useTrendFilt ? emaTrend : na, "EMA", color=color.new(color.yellow, 60), linewidth=1)

// ==========================================
// デバッグテーブル
// ==========================================
var table t = table.new(position.top_right, 2, 12, border_width=1)
if barstate.islast and showDebug
    table.cell(t, 0, 0, "項目", text_color=color.white, bgcolor=color.gray)
    table.cell(t, 1, 0, "値", text_color=color.white, bgcolor=color.gray)
    table.cell(t, 0, 1, "Regime", bgcolor=color.new(color.black, 80))
    table.cell(t, 1, 1, regimeName, bgcolor=regime==1?color.red:regime==2?color.orange:regime==3?color.yellow:regime==4?color.green:color.new(color.black, 80), text_color=color.white)
    table.cell(t, 0, 2, "RSI Up/Dn")
    table.cell(t, 1, 2, str.tostring(adjRsiUp) + " / " + str.tostring(adjRsiDn))
    table.cell(t, 0, 3, "Gap")
    table.cell(t, 1, 3, str.tostring(adjMinGap))
    table.cell(t, 0, 4, "L/R")
    table.cell(t, 1, 4, str.tostring(L) + " / " + str.tostring(R))
    table.cell(t, 0, 5, "HTF Bias")
    table.cell(t, 1, 5, useHtfBias ? (htfBull ? "Bull ▲" : htfBear ? "Bear ▼" : "Flat") : "OFF")
    table.cell(t, 0, 6, "Bull/Bear Q")
    table.cell(t, 1, 6, str.tostring(bullQuality) + " / " + str.tostring(bearQuality))
    table.cell(t, 0, 7, "ATR Ratio")
    table.cell(t, 1, 7, str.tostring(atrRatio, "#.##"))
    table.cell(t, 0, 8, "RSI")
    table.cell(t, 1, 8, str.tostring(rsi, "#.#"))
    table.cell(t, 0, 9, "MACD Hist")
    table.cell(t, 1, 9, str.tostring(hist, "#.####"))
    table.cell(t, 0, 10, "Style/TF")
    table.cell(t, 1, 10, tradeStyle + " / Cat" + str.tostring(tfCat))
    table.cell(t, 0, 11, "ComboWin")
    table.cell(t, 1, 11, str.tostring(comboBars) + " bars")

// ==========================================
// アラート
// ==========================================
alertcondition(bullSignal, "BUY Signal", "BUY signal detected")
alertcondition(bearSignal, "SELL Signal", "SELL signal detected")
