//@version=6
indicator("Momentum & Divergence v8.1 (Debugged Pro)", overlay=true, scale=scale.right, max_lines_count=500, max_labels_count=500, max_bars_back=5000)

// ==========================================
// 1. トレードスタイル & 感度設定
// ==========================================
groupStrat = "📊 トレードスタイル & 感度設定"
tradeStyle = input.string("スイング", "トレードスタイル", options=["短期","スイング","中期","長期"], group=groupStrat)
sensitivity = input.string("Lv3: Scalper (Center)", "感度レベル", options=["Lv1: Swing (Solid)", "Lv2: Strict", "Lv3: Scalper (Center)", "Lv4: Fast", "Lv5: Normal"], group=groupStrat)

useCustom   = input.bool(false, "詳細パラメータを手動設定する", group=groupStrat)
src         = input.source(close, "価格ソース", group=groupStrat)
rsiLen      = input.int(14, "RSI期間", minval=2, group=groupStrat)

// 足自動調整
tfSeconds = timeframe.in_seconds()
tfCat = tfSeconds <= 300 ? 1 : tfSeconds <= 1800 ? 2 : tfSeconds <= 14400 ? 3 : tfSeconds <= 86400 ? 4 : 5

tfScaleL   = tfCat == 1 ? 0.5 : tfCat == 2 ? 0.75 : tfCat == 3 ? 1.0 : tfCat == 4 ? 1.5 : 2.0
tfScaleGap = tfCat == 1 ? 0.5 : tfCat == 2 ? 0.75 : tfCat == 3 ? 1.0 : tfCat == 4 ? 1.25 : 1.5
tfRsiAdj   = tfCat == 1 ? -3 : tfCat == 2 ? -1 : tfCat == 3 ? 0 : tfCat == 4 ? 1 : 2

styleScaleL   = tradeStyle == "短期" ? 0.6 : tradeStyle == "スイング" ? 1.0 : tradeStyle == "中期" ? 1.4 : 2.0
styleScaleGap = tradeStyle == "短期" ? 0.5 : tradeStyle == "スイング" ? 1.0 : tradeStyle == "中期" ? 1.3 : 1.8
styleRsiAdj   = tradeStyle == "短期" ? -2 : tradeStyle == "スイング" ? 0 : tradeStyle == "中期" ? 1 : 2

var int baseL = na
var int baseR = na
var int baseGap = na
var int baseRsiUp = na
var int baseRsiDn = na

if sensitivity == "Lv1: Swing (Solid)"
    baseL := 20
    baseR := 20
    baseGap := 20
    baseRsiUp := 60
    baseRsiDn := 40
else if sensitivity == "Lv2: Strict"
    baseL := 10
    baseR := 10
    baseGap := 15
    baseRsiUp := 58
    baseRsiDn := 42
else if sensitivity == "Lv3: Scalper (Center)"
    baseL := 2
    baseR := 2
    baseGap := 2
    baseRsiUp := 52
    baseRsiDn := 48
else if sensitivity == "Lv4: Fast"
    baseL := 4
    baseR := 4
    baseGap := 5
    baseRsiUp := 54
    baseRsiDn := 46
else
    baseL := 6
    baseR := 6
    baseGap := 10
    baseRsiUp := 55
    baseRsiDn := 45

scaledL = int(math.max(1, math.round(baseL * tfScaleL * styleScaleL)))
scaledR = int(math.max(1, math.round(baseR * tfScaleL * styleScaleL)))
scaledGap = int(math.max(1, math.round(baseGap * tfScaleGap * styleScaleGap)))
scaledRsiUp = int(math.min(70, math.max(50, baseRsiUp + tfRsiAdj + styleRsiAdj)))
scaledRsiDn = int(math.max(30, math.min(50, baseRsiDn - tfRsiAdj - styleRsiAdj)))

L      = useCustom ? input.int(6, "Pivot 左", group=groupStrat) : scaledL
R      = useCustom ? input.int(6, "Pivot 右", group=groupStrat) : scaledR
minGap = useCustom ? input.int(10, "Pivot間隔", group=groupStrat) : scaledGap
rsiUp  = useCustom ? input.int(55, "RSI基準(上)", group=groupStrat) : scaledRsiUp
rsiDn  = useCustom ? input.int(45, "RSI基準(下)", group=groupStrat) : scaledRsiDn

// MACD設定
groupMACD = "MACD設定"
baseFast = input.int(12, "MACD Fast", group=groupMACD)
baseSlow = input.int(26, "MACD Slow", group=groupMACD)
baseSig  = input.int(9, "MACD Signal", group=groupMACD)
macdTfScale = tfCat == 1 ? 0.7 : tfCat == 2 ? 0.85 : tfCat == 3 ? 1.0 : tfCat == 4 ? 1.0 : 1.2
fast = useCustom ? baseFast : int(math.max(3, math.round(baseFast * macdTfScale)))
slow = useCustom ? baseSlow : int(math.max(8, math.round(baseSlow * macdTfScale)))
sig  = useCustom ? baseSig : int(math.max(3, math.round(baseSig * macdTfScale)))

// ==========================================
// 2. レジーム & エッジフィルタ
// ==========================================
groupRegime = "🔄 レジーム自動判定"
useRegime = input.bool(true, "レジーム自動調整を有効化", group=groupRegime)
regimeLookback = input.int(60, "レジーム判定ルックバック", minval=20, maxval=200, group=groupRegime)

regimeEma = ta.ema(close, 200)
regimeAtr = ta.atr(14)
regimeAtrPct = close != 0 ? (regimeAtr / close) * 100.0 : 0.0
avgAtrPct = ta.sma(regimeAtrPct, regimeLookback)
atrRatio = avgAtrPct > 0 ? regimeAtrPct / avgAtrPct : 1.0
recentHigh = ta.highest(high, regimeLookback)
drawdownPct = recentHigh > 0 ? ((recentHigh - close) / recentHigh) * 100.0 : 0.0
roc10 = ta.roc(close, 10)

var int regime = 5
if drawdownPct > 15 and roc10 < -5 and atrRatio > 1.8
    regime := 1
else if close < regimeEma and roc10 < -2
    regime := 2
else if atrRatio > 1.6 and math.abs(ta.roc(regimeEma, 5)) < 0.7
    regime := 3
else if close > regimeEma and roc10 > 2
    regime := 4
else
    regime := 5

regimeName = regime == 1 ? "暴落" : regime == 2 ? "下降" : regime == 3 ? "高ボラ" : regime == 4 ? "上昇" : "通常"
regimeThreshAdj = regime == 1 ? -4 : regime == 2 ? -2 : regime == 3 ? -2 : regime == 4 ? 2 : 0
adjRsiUp = useRegime ? int(math.min(70, math.max(50, rsiUp + regimeThreshAdj))) : rsiUp
adjRsiDn = useRegime ? int(math.max(30, math.min(50, rsiDn - regimeThreshAdj))) : rsiDn
adjMinGap = useRegime ? int(math.max(1, math.round(minGap * (regime == 1 ? 0.75 : regime == 4 ? 1.05 : 1.0)))) : minGap

// 勝率改善向け: HTFバイアス + クオリティスコア
groupEdge = "🏆 勝率改善フィルタ"
useHtfBias = input.bool(true, "上位足EMA方向を必須化", group=groupEdge)
htfTf = input.string("D", "上位足", options=["240", "D", "W"], group=groupEdge)
htfEmaLen = input.int(200, "上位足EMA", minval=20, group=groupEdge)
minQuality = input.int(3, "最小クオリティ(0-5)", minval=0, maxval=5, group=groupEdge)

htfClose = request.security(syminfo.tickerid, htfTf, close)
htfEma = request.security(syminfo.tickerid, htfTf, ta.ema(close, htfEmaLen))
htfBull = htfClose > htfEma
htfBear = htfClose < htfEma

// ==========================================
// 3. ロジック
// ==========================================
groupC = "確定ロジック"
useTrendFilt = input.bool(true, "EMAトレンド条件", group=groupC)
maLen = input.int(200, "EMA期間", group=groupC)
trendBars = input.int(5, "EMA向き確認本数", group=groupC)
useMACDconf = input.bool(true, "MACDクロス必須", group=groupC)
useRSIconf = input.bool(true, "RSI>50/<50必須", group=groupC)

rsi = ta.rsi(src, rsiLen)
macdLine = ta.ema(src, fast) - ta.ema(src, slow)
signalLine = ta.ema(macdLine, sig)
hist = macdLine - signalLine

momUp = ta.crossover(hist, 0) and rsi > adjRsiUp
momDn = ta.crossunder(hist, 0) and rsi < adjRsiDn

f_div(srcSeries, oscSeries, int L_, int R_, int gap_, bool isBull) =>
    float pivotVal = isBull ? ta.pivotlow(srcSeries, L_, R_) : ta.pivothigh(srcSeries, L_, R_)
    float oscVal = isBull ? ta.pivotlow(oscSeries, L_, R_) : ta.pivothigh(oscSeries, L_, R_)
    var float prevPivot = na
    var float prevOsc = na
    var int prevBar = na
    bool detected = false

    if not na(pivotVal) and not na(oscVal)
        currBar = bar_index - R_
        gapOK = not na(prevBar) and (currBar - prevBar >= gap_)
        cond = isBull ? (pivotVal < prevPivot and oscVal > prevOsc) : (pivotVal > prevPivot and oscVal < prevOsc)
        if gapOK and cond
            detected := true
        prevPivot := pivotVal
        prevOsc := oscVal
        prevBar := currBar
    detected

bullDiv = f_div(src, rsi, L, R, adjMinGap, true) or f_div(src, hist, L, R, adjMinGap, true)
bearDiv = f_div(src, rsi, L, R, adjMinGap, false) or f_div(src, hist, L, R, adjMinGap, false)

emaTrend = ta.ema(close, maLen)
emaUp = ta.rising(emaTrend, trendBars)
emaDn = ta.falling(emaTrend, trendBars)
trendBullOK = (not useTrendFilt) or close > emaTrend or emaUp
trendBearOK = (not useTrendFilt) or close < emaTrend or emaDn

momBullOK = (not useMACDconf) or ta.crossover(macdLine, signalLine) or ta.crossover(hist, 0)
momBearOK = (not useMACDconf) or ta.crossunder(macdLine, signalLine) or ta.crossunder(hist, 0)
rsiBullOK = (not useRSIconf) or rsi > 50
rsiBearOK = (not useRSIconf) or rsi < 50

bullQuality = (trendBullOK ? 1 : 0) + (momBullOK ? 1 : 0) + (rsiBullOK ? 1 : 0) + (atrRatio <= 1.8 ? 1 : 0) + (close > emaTrend ? 1 : 0)
bearQuality = (trendBearOK ? 1 : 0) + (momBearOK ? 1 : 0) + (rsiBearOK ? 1 : 0) + (atrRatio <= 1.8 ? 1 : 0) + (close < emaTrend ? 1 : 0)

bullSignal = momUp and bullDiv and trendBullOK and (not useHtfBias or htfBull) and bullQuality >= minQuality
bearSignal = momDn and bearDiv and trendBearOK and (not useHtfBias or htfBear) and bearQuality >= minQuality

// ==========================================
// 4. 描画
// ==========================================
groupView = "表示制御"
showLabels = input.bool(true, "ラベル表示", group=groupView)
showDebug = input.bool(true, "デバッグテーブル", group=groupView)

if showLabels and bullSignal
    label.new(bar_index, low, "BUY", style=label.style_label_up, color=color.new(color.lime, 0), textcolor=color.white, size=size.small)
if showLabels and bearSignal
    label.new(bar_index, high, "SELL", style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

var table t = table.new(position.top_right, 2, 8, border_width=1)
if barstate.islast and showDebug
    table.cell(t, 0, 0, "項目", text_color=color.white, bgcolor=color.black)
    table.cell(t, 1, 0, "値", text_color=color.white, bgcolor=color.black)
    table.cell(t, 0, 1, "Regime")
    table.cell(t, 1, 1, regimeName)
    table.cell(t, 0, 2, "RSI Up/Dn")
    table.cell(t, 1, 2, str.tostring(adjRsiUp) + "/" + str.tostring(adjRsiDn))
    table.cell(t, 0, 3, "Gap")
    table.cell(t, 1, 3, str.tostring(adjMinGap))
    table.cell(t, 0, 4, "HTF Bias")
    table.cell(t, 1, 4, useHtfBias ? (htfBull ? "Bull" : htfBear ? "Bear" : "Flat") : "OFF")
    table.cell(t, 0, 5, "Bull/Bear Q")
    table.cell(t, 1, 5, str.tostring(bullQuality) + "/" + str.tostring(bearQuality))
    table.cell(t, 0, 6, "ATR Ratio")
    table.cell(t, 1, 6, str.tostring(atrRatio, "#.##"))
    table.cell(t, 0, 7, "Style/TF")
    table.cell(t, 1, 7, tradeStyle + " / " + str.tostring(tfCat))

alertcondition(bullSignal, "Bull Signal", "Bull signal - " + regimeName)
alertcondition(bearSignal, "Bear Signal", "Bear signal - " + regimeName)
