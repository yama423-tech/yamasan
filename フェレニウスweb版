<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>円弧すべり安定計算 v2.0</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=JetBrains+Mono:wght@400;600&display=swap');

  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #1c2330;
    --border: #30363d;
    --accent: #e6a817;
    --accent2: #4fc3f7;
    --danger: #f85149;
    --success: #3fb950;
    --warn: #d29922;
    --text: #e6edf3;
    --text-muted: #8b949e;
    --text-dim: #484f58;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ── HEADER ── */
  header {
    background: linear-gradient(135deg, #0d1117 0%, #1a2332 50%, #0d1117 100%);
    border-bottom: 1px solid var(--border);
    padding: 24px 40px;
    display: flex;
    align-items: center;
    gap: 20px;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
  }

  .header-icon {
    width: 44px; height: 44px;
    background: var(--accent);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
  }

  header h1 {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text);
  }

  header p {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .version-badge {
    margin-left: auto;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent);
  }

  /* ── LAYOUT ── */
  .main {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 0;
    min-height: calc(100vh - 73px);
  }

  /* ── SIDEBAR ── */
  .sidebar {
    background: var(--surface);
    border-right: 1px solid var(--border);
    padding: 24px;
    overflow-y: auto;
    position: sticky;
    top: 73px;
    height: calc(100vh - 73px);
  }

  .section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-label::before {
    content: '';
    width: 3px; height: 12px;
    background: var(--accent);
    border-radius: 2px;
  }

  .form-group {
    margin-bottom: 14px;
  }

  label {
    display: block;
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 5px;
  }

  label span {
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent2);
    font-size: 11px;
  }

  input[type="number"], select {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 8px 10px;
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    transition: border-color 0.2s;
    outline: none;
  }

  input[type="number"]:focus, select:focus {
    border-color: var(--accent);
  }

  .toggle-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .toggle {
    position: relative;
    width: 40px; height: 22px;
    flex-shrink: 0;
  }

  .toggle input { display: none; }

  .toggle-slider {
    position: absolute;
    inset: 0;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 11px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .toggle-slider::after {
    content: '';
    position: absolute;
    left: 3px; top: 3px;
    width: 14px; height: 14px;
    background: var(--text-muted);
    border-radius: 50%;
    transition: transform 0.2s, background 0.2s;
  }

  .toggle input:checked + .toggle-slider { background: var(--accent); border-color: var(--accent); }
  .toggle input:checked + .toggle-slider::after { transform: translateX(18px); background: #000; }

  .toggle-label { font-size: 12px; color: var(--text-muted); }

  .sub-params {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px;
    margin-bottom: 16px;
    display: none;
  }

  .sub-params.active { display: block; }

  .hint {
    font-size: 10px;
    color: var(--text-dim);
    margin-top: 4px;
  }

  .ref-table {
    width: 100%;
    font-size: 10px;
    border-collapse: collapse;
    margin-top: 6px;
  }

  .ref-table th {
    background: var(--bg);
    padding: 4px 6px;
    text-align: left;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  .ref-table td {
    padding: 3px 6px;
    border: 1px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent2);
  }

  .run-btn {
    width: 100%;
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 8px;
    padding: 13px;
    font-size: 14px;
    font-weight: 700;
    font-family: 'Noto Sans JP', sans-serif;
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: opacity 0.2s, transform 0.1s;
    margin-top: 8px;
  }

  .run-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .run-btn:active { transform: translateY(0); }

  .spacer { height: 20px; }

  /* ── CONTENT ── */
  .content {
    padding: 32px 40px;
    overflow-y: auto;
  }

  .placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 60vh;
    color: var(--text-dim);
    gap: 16px;
  }

  .placeholder-icon { font-size: 64px; opacity: 0.3; }
  .placeholder p { font-size: 16px; }

  /* ── RESULT CARDS ── */
  .result-section { margin-bottom: 36px; }

  .result-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .result-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .cards-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
  }

  .stat-card.ok::before { background: var(--success); }
  .stat-card.warn::before { background: var(--warn); }
  .stat-card.danger::before { background: var(--danger); }
  .stat-card.info::before { background: var(--accent2); }

  .stat-label {
    font-size: 10px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }

  .stat-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 28px;
    font-weight: 600;
    line-height: 1;
  }

  .stat-card.ok .stat-value { color: var(--success); }
  .stat-card.warn .stat-value { color: var(--warn); }
  .stat-card.danger .stat-value { color: var(--danger); }
  .stat-card.info .stat-value { color: var(--accent2); }

  .stat-sub {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 6px;
  }

  /* ── TABLE ── */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    margin-bottom: 8px;
  }

  .data-table th {
    background: var(--surface2);
    padding: 8px 12px;
    text-align: right;
    color: var(--text-muted);
    border: 1px solid var(--border);
    font-weight: 500;
    white-space: nowrap;
  }

  .data-table th:first-child { text-align: left; }

  .data-table td {
    padding: 7px 12px;
    border: 1px solid var(--border);
    text-align: right;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
  }

  .data-table td:first-child {
    text-align: left;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 12px;
    color: var(--text-muted);
  }

  .data-table tr:nth-child(even) td { background: rgba(255,255,255,0.02); }

  .data-table tr.highlight td { background: rgba(230,168,23,0.08); }
  .data-table tr.highlight td:first-child { color: var(--accent); }

  .fs-ok { color: var(--success); font-weight: 600; }
  .fs-warn { color: var(--warn); font-weight: 600; }
  .fs-ng { color: var(--danger); font-weight: 600; }

  /* ── CHART ── */
  .chart-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 20px;
  }

  .chart-title {
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 12px;
    letter-spacing: 0.05em;
  }

  canvas { max-height: 280px; }

  /* ── NOTICE BOX ── */
  .notice {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 12px 16px;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 20px;
    line-height: 1.8;
  }

  .notice strong { color: var(--accent); }

  /* ── FINDINGS ── */
  .finding-item {
    display: flex;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
  }

  .finding-icon { font-size: 16px; flex-shrink: 0; }
  .finding-text { color: var(--text-muted); line-height: 1.7; }
  .finding-text strong { color: var(--text); }

  /* ── DIAGRAM ── */
  .diagram-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 20px;
  }

  svg text { font-family: 'JetBrains Mono', monospace; }

  @media (max-width: 900px) {
    .main { grid-template-columns: 1fr; }
    .sidebar { position: static; height: auto; }
    .content { padding: 20px; }
  }
</style>
</head>
<body>

<header>
  <div class="header-icon">⛰</div>
  <div>
    <h1>円弧すべり安定計算</h1>
    <p>Fellenius法 ／ 地震時水平震度法 ／ 最危険円弧探索</p>
  </div>
  <div class="version-badge">v2.0</div>
</header>

<div class="main">
  <!-- ═══ SIDEBAR ═══ -->
  <aside class="sidebar">

    <div class="section-label">基本条件</div>

    <div class="form-group">
      <label>単位体積重量 <span>γ (t/m³)</span></label>
      <input type="number" id="gamma" value="1.8" step="0.1" min="1.0" max="2.5">
    </div>
    <div class="form-group">
      <label>斜面勾配 H比 <span>（1:X → Xを入力）</span></label>
      <input type="number" id="slope_h" value="2.0" step="0.1" min="0.5" max="5.0">
    </div>
    <div class="form-group">
      <label>斜面高さ <span>H (m)</span></label>
      <input type="number" id="height" value="5.0" step="0.5" min="1.0">
    </div>
    <div class="form-group">
      <label>円弧半径初期値 <span>R (m)</span></label>
      <input type="number" id="radius" value="5" step="0.1" min="1.0">
    </div>
    <div class="form-group">
      <label>ブロック分割数 <span>n_slice</span></label>
      <input type="number" id="nslice" value="20" step="1" min="5" max="100">
    </div>
    <div class="form-group">
      <label>粘着力 <span>c (t/m²)</span></label>
      <input type="number" id="cohesion" value="2.5" step="0.1" min="0">
    </div>
    <div class="form-group">
      <label>内部摩擦角 <span>φ (°)</span></label>
      <input type="number" id="phi" value="30" step="1" min="0" max="50">
    </div>
    <div class="form-group">
      <label>目標安全率（常時） <span>Fs_target</span></label>
      <input type="number" id="fs_target" value="1.2" step="0.05" min="1.0">
    </div>

    <div class="spacer"></div>
    <div class="section-label">地震時慣性力</div>

    <div class="toggle-row">
      <label class="toggle">
        <input type="checkbox" id="eq_enable" checked onchange="toggleEQ()">
        <span class="toggle-slider"></span>
      </label>
      <span class="toggle-label">地震時計算を実施</span>
    </div>

    <div class="sub-params active" id="eq_params">
      <div class="form-group">
        <label>設計水平震度 <span>kh</span></label>
        <input type="number" id="kh" value="0.15" step="0.01" min="0" max="0.5">
        <div class="hint">参考基準値：</div>
        <table class="ref-table">
          <tr><th>基準</th><th>kh</th><th>地震時Fs</th></tr>
          <tr><td>道路土工</td><td>0.15〜0.20</td><td>1.00</td></tr>
          <tr><td>宅地防災</td><td>0.15</td><td>1.00</td></tr>
          <tr><td>河川堤防</td><td>0.12</td><td>1.00</td></tr>
        </table>
      </div>
      <div class="form-group">
        <label>目標安全率（地震時） <span>Fs_eq_target</span></label>
        <input type="number" id="fs_eq_target" value="1.0" step="0.05" min="0.5">
      </div>
      <div class="toggle-row">
        <label class="toggle">
          <input type="checkbox" id="kv_enable" onchange="toggleKV()">
          <span class="toggle-slider"></span>
        </label>
        <span class="toggle-label">鉛直震度を考慮（kv = kh/2）</span>
      </div>
    </div>

    <div class="spacer"></div>
    <div class="section-label">最危険円弧探索</div>

    <div class="toggle-row">
      <label class="toggle">
        <input type="checkbox" id="search_enable" checked onchange="toggleSearch()">
        <span class="toggle-slider"></span>
      </label>
      <span class="toggle-label">最危険円弧探索を実施</span>
    </div>

    <div class="sub-params active" id="search_params">
      <div class="form-group">
        <label>R探索 分割数 <span>nR</span></label>
        <input type="number" id="nR" value="8" step="1" min="3" max="20">
      </div>
      <div class="form-group">
        <label>Xc探索 分割数 <span>nX</span></label>
        <input type="number" id="nX" value="5" step="1" min="3" max="15">
      </div>
      <div class="form-group">
        <label>Yc探索 分割数 <span>nY</span></label>
        <input type="number" id="nY" value="5" step="1" min="3" max="15">
      </div>
    </div>

    <div class="spacer"></div>
    <div class="section-label">Rシミュレーション</div>

    <div class="form-group">
      <label>試行回数 <span>n</span></label>
      <input type="number" id="nsim" value="30" step="1" min="5" max="100">
    </div>
    <div class="form-group">
      <label>R変動幅 <span>± (%)</span></label>
      <input type="number" id="r_range" value="50" step="1" min="1" max="50">
    </div>

    <div class="spacer"></div>
    <button class="run-btn" onclick="runCalc()">▶ 計算実行</button>
    <div class="spacer"></div>

  </aside>

  <!-- ═══ CONTENT ═══ -->
  <main class="content" id="result_area">
    <div class="placeholder">
      <div class="placeholder-icon">🏔</div>
      <p>左パネルでパラメータを設定し、計算実行を押してください</p>
    </div>
  </main>
</div>

<script>
function toggleEQ() {
  document.getElementById('eq_params').classList.toggle('active', document.getElementById('eq_enable').checked);
}
function toggleKV() {}
function toggleSearch() {
  document.getElementById('search_params').classList.toggle('active', document.getElementById('search_enable').checked);
}

function calcFs(R, Xc, Yc, p) {
  const { gamma, L, nslice, c, tanPhi, kh, kv_eff } = p;
  const b = L / nslice;
  let sumResist = 0, sumDrive = 0;
  let sumResistEq = 0, sumDriveEq = 0;
  let validSlices = 0;

  for (let i = 0; i < nslice; i++) {
    const xi = (i + 0.5) * b;
    const dx = xi - Xc;
    const sinA_val = dx / R;
    if (Math.abs(sinA_val) > 0.999) continue;
    const sinA = sinA_val;
    const cosA = Math.sqrt(1 - sinA * sinA);
    const yBottom = Yc - Math.sqrt(R * R - dx * dx);
    const xAbs = xi;
    let yTop;
    if (xAbs <= 0) yTop = 0;
    else if (xAbs >= L) yTop = p.H;
    else yTop = (xAbs / L) * p.H;
    const hi = yTop - yBottom;
    if (hi <= 0) continue;
    validSlices++;
    const Wi = gamma * b * hi;
    const li = b / cosA;
    const resist = c * li + Wi * cosA * tanPhi;
    const drive  = Wi * sinA;
    sumResist += resist;
    sumDrive  += drive;
    const Wi_eq = Wi * (1 - kv_eff);
    const resistEq = c * li + (Wi_eq * cosA - kh * Wi_eq * sinA) * tanPhi;
    const driveEq  = Wi_eq * sinA + kh * Wi_eq * cosA;
    sumResistEq += resistEq;
    sumDriveEq  += driveEq;
  }

  if (validSlices < nslice * 0.4 || sumDrive <= 0) return { Fs: null, Fs_eq: null, valid: false };
  return { Fs: sumResist / sumDrive, Fs_eq: sumResistEq / sumDriveEq, valid: true };
}

function runCalc() {
  const gamma   = parseFloat(document.getElementById('gamma').value);
  const slopeH  = parseFloat(document.getElementById('slope_h').value);
  const H       = parseFloat(document.getElementById('height').value);
  const R0      = parseFloat(document.getElementById('radius').value);
  const nslice  = parseInt(document.getElementById('nslice').value);
  const c       = parseFloat(document.getElementById('cohesion').value);
  const phiDeg  = parseFloat(document.getElementById('phi').value);
  const fs_t    = parseFloat(document.getElementById('fs_target').value);
  const eq_on   = document.getElementById('eq_enable').checked;
  const kh      = eq_on ? parseFloat(document.getElementById('kh').value) : 0;
  const fs_eq_t = eq_on ? parseFloat(document.getElementById('fs_eq_target').value) : 1.0;
  const kv_on   = document.getElementById('kv_enable').checked;
  const search_on = document.getElementById('search_enable').checked;
  const nR      = parseInt(document.getElementById('nR').value);
  const nX      = parseInt(document.getElementById('nX').value);
  const nY      = parseInt(document.getElementById('nY').value);
  const nsim    = parseInt(document.getElementById('nsim').value);
  const r_pct   = parseFloat(document.getElementById('r_range').value) / 100;

  const L = H * slopeH;
  const tanPhi = Math.tan(phiDeg * Math.PI / 180);
  const kv_eff = kv_on ? kh / 2 : 0;
  const p = { gamma, L, H, nslice, c, tanPhi, kh, kv_eff };

  const Xc0 = L / 2;
  const Yc0 = Math.sqrt(R0 * R0 - (L / 2) * (L / 2));
  const single = calcFs(R0, Xc0, Yc0, p);

  let searchResults = [];
  let minCase_normal = null, minCase_eq = null;

  if (search_on) {
    const R_min = R0 * 0.7, R_max = R0 * 1.5;
    const Xc_min = L * 0.3, Xc_max = L * 0.7;
    for (let ri = 0; ri < nR; ri++) {
      const R = R_min + (R_max - R_min) * ri / (nR - 1);
      for (let xi = 0; xi < nX; xi++) {
        const Xc = Xc_min + (Xc_max - Xc_min) * xi / (nX - 1);
        const Yc_base = Math.max(R * 0.5, Math.sqrt(Math.max(0, R * R - (L / 2) * (L / 2))));
        const Yc_min2 = Yc_base * 0.8, Yc_max2 = Yc_base * 1.4;
        for (let yi = 0; yi < nY; yi++) {
          const Yc = Yc_min2 + (Yc_max2 - Yc_min2) * yi / (nY - 1);
          const res = calcFs(R, Xc, Yc, p);
          if (!res.valid) continue;
          searchResults.push({ R, Xc, Yc, Fs: res.Fs, Fs_eq: res.Fs_eq });
        }
      }
    }
    searchResults.sort((a, b) => a.Fs - b.Fs);
    if (searchResults.length > 0) {
      minCase_normal = searchResults[0];
      const sorted_eq = [...searchResults].sort((a, b) => a.Fs_eq - b.Fs_eq);
      minCase_eq = sorted_eq[0];
    }
  }

  const simResults = [];
  for (let i = 0; i < nsim; i++) {
    const R = R0 * (1 - r_pct + 2 * r_pct * i / (nsim - 1));
    const Xc = L / 2;
    const Yc = Math.sqrt(Math.max(0, R * R - (L / 2) * (L / 2)));
    const res = calcFs(R, Xc, Yc, p);
    if (res.valid) simResults.push({ i: i + 1, R, Fs: res.Fs, Fs_eq: res.Fs_eq });
  }

  const fsList   = simResults.map(r => r.Fs).filter(f => f !== null);
  const fsEqList = simResults.map(r => r.Fs_eq).filter(f => f !== null);

  const stat = (arr, tgt) => ({
    min: Math.min(...arr).toFixed(3),
    max: Math.max(...arr).toFixed(3),
    avg: (arr.reduce((s, v) => s + v, 0) / arr.length).toFixed(3),
    rate: (arr.filter(v => v >= tgt).length / arr.length * 100).toFixed(0) + '%'
  });

  const st_n  = stat(fsList, fs_t);
  const st_eq = eq_on ? stat(fsEqList, fs_eq_t) : null;

  const fsClass = (fs, tgt) => fs === null ? '' : fs >= tgt * 1.1 ? 'ok' : fs >= tgt ? 'warn' : 'danger';
  const fsTd = (fs, tgt) => {
    if (fs === null) return '<td>—</td>';
    const cls = fs >= tgt * 1.1 ? 'fs-ok' : fs >= tgt ? 'fs-warn' : 'fs-ng';
    return `<td class="${cls}">${fs.toFixed(3)}</td>`;
  };

  const singleFs   = single.valid ? single.Fs   : null;
  const singleFsEq = single.valid ? single.Fs_eq : null;
  const drop = (singleFs && singleFsEq) ? ((singleFs - singleFsEq) / singleFs * 100).toFixed(1) : null;

  const top5rows = searchResults.slice(0, 5).map((r, idx) => `
    <tr class="${idx === 0 ? 'highlight' : ''}">
      <td>${idx + 1}</td>
      <td>${r.R.toFixed(2)}</td>
      <td>${r.Xc.toFixed(2)}</td>
      <td>${r.Yc.toFixed(2)}</td>
      ${fsTd(r.Fs, fs_t)}
      ${eq_on ? fsTd(r.Fs_eq, fs_eq_t) : ''}
    </tr>`).join('');

  const simRows = simResults.map(r => `
    <tr>
      <td>${r.i}</td>
      <td>${r.R.toFixed(3)}</td>
      ${fsTd(r.Fs, fs_t)}
      ${eq_on ? fsTd(r.Fs_eq, fs_eq_t) : ''}
    </tr>`).join('');

  const findings = [];
  if (singleFs !== null) {
    if (singleFs >= fs_t * 1.3) findings.push({ icon: '✅', text: `<strong>常時：十分安全</strong>　Fs = ${singleFs.toFixed(3)} は目標値 ${fs_t} を大きく上回っています。` });
    else if (singleFs >= fs_t) findings.push({ icon: '⚠️', text: `<strong>常時：ぎりぎり安全</strong>　Fs = ${singleFs.toFixed(3)} は目標値付近です。土質定数の信頼性を確認してください。` });
    else findings.push({ icon: '🚨', text: `<strong>常時：不安全</strong>　Fs = ${singleFs.toFixed(3)} は目標値 ${fs_t} を下回ります。対策工が必要です。` });
  }
  if (eq_on && singleFsEq !== null) {
    if (drop !== null) findings.push({ icon: '📉', text: `<strong>地震時低下率：${drop}%</strong>　常時Fs ${singleFs.toFixed(3)} → 地震時Fs ${singleFsEq.toFixed(3)}` });
    if (singleFsEq < fs_eq_t) findings.push({ icon: '🚨', text: `<strong>地震時：不安全</strong>　Fs_eq = ${singleFsEq.toFixed(3)} < 目標 ${fs_eq_t}。地震時対策を検討してください。` });
    else findings.push({ icon: '✅', text: `<strong>地震時：安全</strong>　Fs_eq = ${singleFsEq.toFixed(3)} ≥ 目標 ${fs_eq_t}` });
  }
  if (minCase_normal) {
    const diff = ((R0 - minCase_normal.R) / R0 * 100).toFixed(1);
    findings.push({ icon: '🔍', text: `<strong>最危険円弧（常時）</strong>　R = ${minCase_normal.R.toFixed(2)} m, Xc = ${minCase_normal.Xc.toFixed(2)} m, Yc = ${minCase_normal.Yc.toFixed(2)} m → 最小Fs = ${minCase_normal.Fs.toFixed(3)}。初期設定Rとの差 ${Math.abs(diff)}%。` });
  }
  findings.push({ icon: '📋', text: '<strong>追加確認事項：</strong>地下水位・間隙水圧の把握、土質試験値のばらつき評価（c・φの感度分析）、3次元効果の検討' });

  const findingsHtml = findings.map(f => `
    <div class="finding-item">
      <span class="finding-icon">${f.icon}</span>
      <span class="finding-text">${f.text}</span>
    </div>`).join('');

  const chartId1 = 'chart_sim_' + Date.now();
  const chartId2 = 'chart_search_' + Date.now();

  document.getElementById('result_area').innerHTML = `
  <div class="notice">
    <strong>採用した仮定・制限事項：</strong>
    Fellenius法（簡易分割法） ／ 均等幅スライス ／ 2次元断面解析 ／
    地下水・間隙水圧：<strong>未考慮</strong> ／
    ${eq_on ? `地震時：水平震度法（擬似静的法）kh=${kh}${kv_on ? `、kv=${(kh/2).toFixed(3)}` : '、kv未考慮'}` : '地震時計算：未実施'} ／
    最危険円弧探索：${search_on ? `実施（${nR}×${nX}×${nY}=${nR*nX*nY}格子）` : '未実施'}
  </div>
  <div class="result-section">
    <div class="result-title">入力条件サマリー</div>
    <table class="data-table">
      <tr><td>単位体積重量 γ</td><td>${gamma} t/m³</td><td>斜面勾配</td><td>1:${slopeH}</td></tr>
      <tr><td>斜面高さ H</td><td>${H} m</td><td>底面水平長 L</td><td>${L.toFixed(2)} m</td></tr>
      <tr><td>円弧半径 R₀</td><td>${R0} m</td><td>分割数</td><td>${nslice}</td></tr>
      <tr><td>粘着力 c</td><td>${c} t/m²</td><td>内部摩擦角 φ</td><td>${phiDeg}°</td></tr>
      <tr><td>目標Fs（常時）</td><td>${fs_t}</td><td>目標Fs（地震時）</td><td>${eq_on ? fs_eq_t : '—'}</td></tr>
    </table>
  </div>
  <div class="result-section">
    <div class="result-title">単一ケース結果（初期R = ${R0} m）</div>
    <div class="cards-row">
      <div class="stat-card ${fsClass(singleFs, fs_t)}">
        <div class="stat-label">常時 Fs</div>
        <div class="stat-value">${singleFs ? singleFs.toFixed(3) : '—'}</div>
        <div class="stat-sub">目標 ≥ ${fs_t}</div>
      </div>
      ${eq_on ? `
      <div class="stat-card ${fsClass(singleFsEq, fs_eq_t)}">
        <div class="stat-label">地震時 Fs</div>
        <div class="stat-value">${singleFsEq ? singleFsEq.toFixed(3) : '—'}</div>
        <div class="stat-sub">目標 ≥ ${fs_eq_t}</div>
      </div>
      <div class="stat-card info">
        <div class="stat-label">地震時低下率</div>
        <div class="stat-value">${drop ? drop + '%' : '—'}</div>
        <div class="stat-sub">kh = ${kh}</div>
      </div>` : ''}
    </div>
  </div>
  ${search_on && searchResults.length > 0 ? `
  <div class="result-section">
    <div class="result-title">最危険円弧探索結果（探索格子 ${nR}×${nX}×${nY} = ${nR*nX*nY} 点）</div>
    <div class="cards-row">
      <div class="stat-card ${fsClass(minCase_normal.Fs, fs_t)}">
        <div class="stat-label">最小Fs（常時）</div>
        <div class="stat-value">${minCase_normal.Fs.toFixed(3)}</div>
        <div class="stat-sub">R=${minCase_normal.R.toFixed(2)} Xc=${minCase_normal.Xc.toFixed(2)}</div>
      </div>
      ${eq_on ? `
      <div class="stat-card ${fsClass(minCase_eq.Fs_eq, fs_eq_t)}">
        <div class="stat-label">最小Fs（地震時）</div>
        <div class="stat-value">${minCase_eq.Fs_eq.toFixed(3)}</div>
        <div class="stat-sub">R=${minCase_eq.R.toFixed(2)} Xc=${minCase_eq.Xc.toFixed(2)}</div>
      </div>` : ''}
    </div>
    <p style="font-size:11px;color:var(--text-muted);margin-bottom:10px;">上位5ケース（常時Fsが小さい順）</p>
    <table class="data-table">
      <tr>
        <th style="text-align:center">順位</th>
        <th>R (m)</th><th>Xc (m)</th><th>Yc (m)</th>
        <th>Fs 常時</th>${eq_on ? '<th>Fs 地震時</th>' : ''}
      </tr>
      ${top5rows}
    </table>
    <div class="chart-wrap" style="margin-top:16px;">
      <div class="chart-title">探索結果散布（R vs 常時Fs）</div>
      <canvas id="${chartId2}"></canvas>
    </div>
  </div>` : ''}
  <div class="result-section">
    <div class="result-title">Rシミュレーション結果（n = ${nsim}、変動幅 ±${(r_pct*100).toFixed(0)}%）</div>
    <div class="cards-row">
      <div class="stat-card info"><div class="stat-label">常時 最小Fs</div><div class="stat-value">${st_n.min}</div></div>
      <div class="stat-card info"><div class="stat-label">常時 最大Fs</div><div class="stat-value">${st_n.max}</div></div>
      <div class="stat-card info"><div class="stat-label">常時 平均Fs</div><div class="stat-value">${st_n.avg}</div></div>
      <div class="stat-card ${parseFloat(st_n.rate) === 100 ? 'ok' : 'warn'}">
        <div class="stat-label">目標達成率（常時）</div>
        <div class="stat-value">${st_n.rate}</div>
        <div class="stat-sub">目標 ≥ ${fs_t}</div>
      </div>
      ${eq_on && st_eq ? `
      <div class="stat-card ${parseFloat(st_eq.rate) === 100 ? 'ok' : 'warn'}">
        <div class="stat-label">目標達成率（地震時）</div>
        <div class="stat-value">${st_eq.rate}</div>
        <div class="stat-sub">目標 ≥ ${fs_eq_t}</div>
      </div>` : ''}
    </div>
    <div class="chart-wrap">
      <div class="chart-title">Rシミュレーション：R vs Fs</div>
      <canvas id="${chartId1}"></canvas>
    </div>
    <table class="data-table">
      <tr>
        <th style="text-align:center">試行</th>
        <th>R (m)</th>
        <th>Fs 常時</th>
        ${eq_on ? '<th>Fs 地震時</th>' : ''}
      </tr>
      ${simRows}
    </table>
  </div>
  <div class="result-section">
    <div class="result-title">所見</div>
    ${findingsHtml}
  </div>
  `;

  setTimeout(() => {
    const ctx1 = document.getElementById(chartId1);
    if (ctx1) {
      const ds = [{
        label: '常時 Fs',
        data: simResults.map(r => ({ x: r.R, y: r.Fs })),
        borderColor: '#e6a817', backgroundColor: 'rgba(230,168,23,0.15)',
        pointRadius: 5, tension: 0.3, fill: false
      }];
      if (eq_on) ds.push({
        label: '地震時 Fs',
        data: simResults.map(r => ({ x: r.R, y: r.Fs_eq })),
        borderColor: '#4fc3f7', backgroundColor: 'rgba(79,195,247,0.10)',
        pointRadius: 5, tension: 0.3, fill: false
      });
      new Chart(ctx1, {
        type: 'scatter',
        data: { datasets: ds },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: '#8b949e', font: { size: 11 } } }, annotation: {} },
          scales: {
            x: { title: { display: true, text: 'R (m)', color: '#8b949e' }, ticks: { color: '#8b949e' }, grid: { color: '#30363d' } },
            y: { title: { display: true, text: 'Fs', color: '#8b949e' }, ticks: { color: '#8b949e' }, grid: { color: '#30363d' } }
          }
        }
      });
    }
    if (search_on && searchResults.length > 0) {
      const ctx2 = document.getElementById(chartId2);
      if (ctx2) {
        new Chart(ctx2, {
          type: 'scatter',
          data: { datasets: [{
            label: '探索点（常時Fs）',
            data: searchResults.map(r => ({ x: r.R, y: r.Fs })),
            backgroundColor: searchResults.map(r => r.Fs < fs_t ? 'rgba(248,81,73,0.7)' : r.Fs < fs_t*1.2 ? 'rgba(210,153,34,0.7)' : 'rgba(63,185,80,0.7)'),
            pointRadius: 4
          }]},
          options: {
            responsive: true,
            plugins: { legend: { labels: { color: '#8b949e', font: { size: 11 } } } },
            scales: {
              x: { title: { display: true, text: 'R (m)', color: '#8b949e' }, ticks: { color: '#8b949e' }, grid: { color: '#30363d' } },
              y: { title: { display: true, text: 'Fs 常時', color: '#8b949e' }, ticks: { color: '#8b949e' }, grid: { color: '#30363d' } }
            }
          }
        });
      }
    }
  }, 100);
}
</script>
</body>
</html>
